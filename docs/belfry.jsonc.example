// Belfry subscription config. Copy this to ~/.claude/belfry.jsonc and edit.
//
// Per-slug opt-in. Slugs not listed here are silently ignored — no spam from
// projects you didn't subscribe.
{
  "subscriptions": {
    // Slug = the project name claudelike-bar uses (matches the filename in
    // /tmp/claude-dashboard/<slug>.json). Run `ls /tmp/claude-dashboard/` to
    // see what's currently active.
    "life-planner": {
      "events": ["ready", "error"],
      // Optional: pipe last_prompt/last_response through Claude Haiku to
      // produce 1-line summaries before send. Off by default. Requires
      // ANTHROPIC_API_KEY in the daemon's env. Fails open — if the API call
      // errors or times out, the message falls back to the existing
      // truncate-at-promptCap/responseCap behavior.
      "summarize": true
    },
    "financial-planner": {
      "events": ["ready"]
    },
    // Example: digest mode. Instead of pinging on every event, accumulate
    // them in a buffer and send one Haiku-summarized rollup when the slug
    // goes quiet (or when the windowMs cap is reached). Useful for chatty
    // slugs you want to glance at, not triage in real-time.
    "garden-assist": {
      "events": ["ready", "error"],
      "digest": true
    }
  },

  // Throttle per slug (ms). Default 30000. After belfry sends a message for
  // a slug, further events are dropped until this window expires.
  "throttleMs": 30000,

  // Coalesce window (ms). Default 5000. Multiple events for the same slug
  // within this window collapse into one send describing the latest state.
  // Stops fan-out bursts (e.g. 10 rapid subagent permission prompts) from
  // each producing a separate Telegram message.
  "coalesceMs": 5000,

  // Truncation caps for the prompt + response in each message (chars).
  // Telegram's per-message cap is 4096; the composer wraps the prompt in
  // an expandable blockquote so it doesn't crowd the screen — so keeping
  // these large preserves content without making messages feel attenuated.
  "promptCap": 1500,
  "responseCap": 2500,

  // Rollup-digest mode (per-slug opt-in via "digest": true on a subscription).
  // When digest mode is on, events for that slug bypass the per-event throttle
  // and accumulate in a buffer. The buffer flushes one summarized message
  // when either the slug is quiet for digestIdleMs OR the total burst
  // duration hits digestWindowMs (whichever comes first). Defaults: 15s
  // idle, 60s window.
  "digestIdleMs": 15000,
  "digestWindowMs": 60000,

  // Optional: mesh visibility (#39, scoped). Agent-to-agent messages (send_to,
  // federation relays, bridge replies) normally stay off Telegram entirely —
  // a peer message owes the phone nothing. Set an override to "full" to mirror
  // an agent's mesh traffic to Telegram as it's delivered: any relay whose
  // source OR destination matches the key is sent as a normal outbound message
  // (headered with the source slug, "→ <dest>" on the first line). A bare key
  // like "wintermute" matches that slug on any host (w/wintermute included);
  // a qualified key like "w/wintermute" matches only that host. "telegram" is
  // the default for unmatched relays — leave it "none" unless you want ALL
  // mesh chatter on your phone. Quote-replying a mirrored message routes your
  // reply back to that agent over the mesh.
  "mesh": {
    "telegram": "none",
    "telegramOverrides": {
      "wintermute": "full"
    }
  },

  // Optional: bootstrap nicknames. Same format as the on-disk
  // ~/.local/state/belfry/nicknames.json (managed via /nick, /unnick, /nicks
  // from Telegram). Entries here apply only on first daemon load — the
  // persisted file is authoritative once you've edited nicknames over
  // Telegram, so re-reading this config never overwrites your live state.
  // Validation is the same as /nick: nicknames must match
  // [a-z0-9][a-z0-9-]{0,31} (lowercase enforced via auto-coerce), and slugs
  // must currently exist in the dashboard at startup.
  "nicknames": {
    "ob": "obsidian-vault",
    "fin": "financial-planner",
    "3d": "3d-printing"
  }
}
